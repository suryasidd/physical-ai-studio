# =============================================================================
# .dockerignore — allow-list approach
#
# Ignore everything by default, then selectively allow only the files and
# directories required by the Docker build. This keeps the build context
# small and prevents accidentally leaking secrets, data, or dev artifacts.
# =============================================================================

# Ignore everything
*

# ---- Root-level files needed by the build ----
!pyproject.toml
!uv.lock
!LICENSE
!README.md

# ---- Application-level files needed by the build ----
# The hatch build hook reads application/README.md to transform it
# into the backend's README for the PyPI description.
!application/README.md

# ---- Application: UI ----
!application/ui/package.json
!application/ui/package-lock.json
!application/ui/tsconfig.base.json
!application/ui/tsconfig.json
!application/ui/rsbuild.config.ts
!application/ui/src/

# ---- Application: Backend ----
!application/backend/pyproject.toml
!application/backend/uv.lock
!application/backend/README.md
!application/backend/run.sh
!application/backend/src/
application/backend/src/static/robot-assets
!application/backend/scripts/hatch_build.py

# ---- Application: Trainer ----
!application/trainer/**

# ---- Application: Docker ----
# The Dockerfile is referenced via the `file:` parameter in the build
# action, NOT via COPY, so the docker/ directory does not need to be in
# the build context.  Excluding it avoids leaking .env files and
# prevents unrelated changes (logs, compose, docs) from affecting the
# build-context hash.
# !application/docker/

# Re-exclude artifacts that may appear inside allowed directories
**/__pycache__/
**/*.py[cod]
**/.venv/
**/.mypy_cache/
**/.ruff_cache/
**/.pytest_cache/
**/node_modules/
**/.DS_Store
