# Physical AI Studio trainer service environment variables.
# Copy this file to `.env` in this directory and fill in the values you need.
# `physicalai-trainer` loads this file automatically; unset values fall back
# to the defaults in src/trainer/settings.py.

# Working directory for snapshots, checkpoints, and model archives.
# Defaults to ~/.local/share/physicalai-trainer when unset.
# STORAGE_DIR=

# Concurrency cap for the queue worker (1-8). Defaults to a single GPU job.
# TRAINER_MAX_CONCURRENT_JOBS=1


# Server
# HOST=0.0.0.0
# PORT=8001

# Uploaded-dataset safety bounds (http transfer). Mirror the studio backend's
# data-import guards so a malicious or corrupt upload cannot exhaust disk.
# TRAINER_MAX_UNCOMPRESSED_BYTES=214748364800
# TRAINER_MIN_FREE_BYTES=1073741824

# Hugging Face token, required to pull dataset snapshots from ephemeral
# private HuggingFace repos (hf transfer mode). Never commit a real token.
HF_TOKEN=
