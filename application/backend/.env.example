# Physical AI Studio backend environment variables.
# Copy this file to `.env` in this directory and fill in the values you need.
# `physicalai-studio remote` loads this file automatically; unset values fall
# back to the defaults in src/settings.py.

# Application
DEBUG=false
ENVIRONMENT=dev
# Directory for datasets, models, snapshots, cache, logs, and the database.
# Defaults to a platform-appropriate app-data directory when unset.
# STORAGE_DIR=
# Directory containing a prebuilt web UI to serve as static files (optional).
# STATIC_FILES_DIR=

# Data import/upload safety (shared for dataset/model/project imports)
# DATA_IMPORT_MAX_UNCOMPRESSED_BYTES=214748364800
# DATA_IMPORT_MAX_UPLOAD_BYTES=107374182400
# DATA_IMPORT_MIN_FREE_BYTES=1073741824

# Training mode
# "local" runs training in-process (requires the [train] extra with torch).
# "remote" offloads training to a trainer service started with `physicalai-trainer`.
TRAINING_MODE=local
# Base URL of the remote trainer service. Required when TRAINING_MODE=remote.
# TRAINER_URL=http://gpu-host:8001
# How the dataset snapshot reaches the trainer: "http" (default) or "hf".
# TRAINER_DATASET_TRANSFER=http
# HuggingFace org/user namespace for ephemeral snapshot dataset repos (hf transfer only).
# TRAINER_HF_NAMESPACE=
# Seconds to wait for trainer HTTP requests (excludes long-poll/SSE streams).
# TRAINER_REQUEST_TIMEOUT_S=30.0
# Seconds to wait between chunks while streaming the model artifact.
# TRAINER_DOWNLOAD_READ_TIMEOUT_S=120.0

# Server
HOST=0.0.0.0
PORT=7860
# Overrides PORT when set (used by some deployment environments).
# HTTP_SERVER_PORT=

# Database
# DATABASE_FILE=physicalai.db
DB_ECHO=false

# Alembic
# ALEMBIC_CONFIG_PATH=src/alembic.ini
# ALEMBIC_SCRIPT_LOCATION=src/alembic

# Proxy settings
no_proxy=localhost,127.0.0.1,::1

# Hugging Face token, used by the remote training backend to authenticate
# dataset/model uploads. Never commit a real token to source control.
HF_TOKEN=

# `physicalai-studio remote` launcher options (not read by the app itself).
# Hardware extra to sync: cpu, cuda, or xpu.
# DEVICE=cpu
# Set to false to skip `uv sync` on launch.
# SYNC=true
