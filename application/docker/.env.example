# Corporate proxies
# If your network requires a proxy, set these before building or starting the
# container. Verify propagation with:
#   docker compose config | grep -i proxy
#   docker exec physical-ai-studio-<profile> env | grep -i proxy
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
http_proxy=
https_proxy=
no_proxy=

# Container image registry and version tag
REGISTRY=ghcr.io/open-edge-platform/
IMAGE_TAG=main

PORT=7860

# Hardware profile: cpu, xpu, or cuda
# This is a built-in Docker Compose variable that selects which
# profiled service to start (see docker-compose.yaml).
COMPOSE_PROFILES=cpu

# Persist the SYCL kernel cache across container restarts so the first
# model inference (which compiles hundreds of SYCL kernels) only pays
# the full ~minutes-long compile cost once.
SYCL_CACHE_PERSISTENT=1
SYCL_CACHE_DIR=/app/storage/.sycl-cache
# Workaround for iGPU training stuck issue with Level Zero v2 adapter
# by disabling it.
SYCL_UR_USE_LEVEL_ZERO_V2=0

# Container user UID/GID — override to match your host user so that
# bind-mounted volumes (e.g. calibration data) have correct ownership.
# Run `id -u` and `id -g` to find your host values.
# APP_UID=1000
# APP_GID=1000

# Host device-group GIDs — override when your host uses different GIDs
# than the Debian/Ubuntu defaults (e.g. Arch Linux). These are passed to
# Docker's group_add so the container process can access host devices.
# Run `application/docker/setup-devices.sh` to auto-detect these values.
#
# The defaults (dialout, plugdev, video) are group names that Docker
# resolves against the container's /etc/group. This works on Debian/Ubuntu
# hosts where the GIDs match. On other distros, set numeric GIDs here.
# VIDEO_GID=984
# DIALOUT_GID=985
# PLUGDEV_GID=46
# RENDER_GID=989       # Intel GPU render nodes (XPU non-privileged mode)

# Hugging Face token for Hub-backed model downloads (for example, SmolVLA, Pi0)
HF_TOKEN=
